# Dependencies
node_modules/
**/node_modules/

# Package manager caches
.npm/
.pnpm-store/
.yarn/
!.yarn/releases/
!.yarn/plugins/
!.yarn/sdks/
!.yarn/versions/

# Build outputs
.next/
out/
dist/
build/
.turbo/
.vercel/
.strapi/

# Test and coverage outputs
coverage/
.nyc_output/
playwright-report/
test-results/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl
!infrastructure/terraform/environments/**/.terraform.lock.hcl
!infrastructure/terraform/future/environments/**/.terraform.lock.hcl
!infrastructure/terraform/simple/.terraform.lock.hcl

# Kubernetes and Helm generated files
*.kubeconfig
charts/

# Strapi runtime uploads can be large and environment-specific.
apps/strapi/public/uploads/*
!apps/strapi/public/uploads/.gitkeep
